{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
    "crons": [
    {
      "path": "/api/cron-recurrentes",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/sheets.js": { "memory": 256, "maxDuration": 10 }
  }
}
