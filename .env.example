# ─── Firebase ───────────────────────────────────────────────
VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── Google Sheets ──────────────────────────────────────────
VITE_SHEETS_ID=tu_google_sheets_id_aqui

# ─── Google Service Account (para el proxy API en Vercel) ───
# Estos van SOLO en Vercel como variables de entorno del servidor
# NO los pongas con prefijo VITE_ — no deben exponerse al cliente
GOOGLE_SERVICE_ACCOUNT_EMAIL=familyfinance-backend@proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada\n-----END PRIVATE KEY-----\n"

# ─── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=tu_anthropic_api_key

# ─── Google Cloud Vision ────────────────────────────────────
GOOGLE_VISION_API_KEY=tu_vision_api_key

# ─── ExchangeRate API ───────────────────────────────────────
VITE_EXCHANGE_RATE_API_KEY=tu_exchangerate_api_key
